# This is a template for the .env file.
# Copy this file to .env and fill in your actual API keys and endpoints.

# --- AZURE CREDENTIALS ---
# A single API key may be used for multiple Azure services.
AZURE_API_KEY="YOUR_AZURE_API_KEY"

# Azure OpenAI Endpoint (for GPT-5.1, o4-mini, etc.)
# Found in your Azure portal under "Keys and Endpoint" for the Cognitive Services resource.
AZURE_OPENAI_API_ENDPOINT="https://your-resource.cognitiveservices.azure.com/"

# Azure AI Foundry Endpoint (for DeepSeek, etc.)
# This is typically the same resource as above, but may have a different path.
AZURE_AI_FOUNDRY_ENDPOINT="https://your-resource.services.ai.azure.com/openai/v1/"

# --- GOOGLE CLOUD (VERTEX AI) ---
# Authentication for Vertex AI is typically handled by running `gcloud auth application-default login`
# in your terminal. The project ID is configured in `src/models_config.py`.

# --- AWS (BEDROCK) ---
# (Optional) If you are using models hosted on AWS Bedrock.
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="YOUR_AWS_ACCESS_KEY_ID"
AWS_SECRET_ACCESS_KEY="YOUR_AWS_SECRET_ACCESS_KEY"
