{
  "name": "dnum",
  "version": "2.17.0",
  "type": "module",
  "license": "MIT",
  "author": "Pierre Bertet <hi@bpier.re>",
  "description": "Small library for big decimal numbers.",
  "keywords": [
    "typescript",
    "decimal-number",
    "big-decimal",
    "formatting",
    "currency",
    "bigint"
  ],
  "homepage": "https://github.com/bpierre/dnum",
  "bugs": "https://github.com/bpierre/dnum/issues",
  "repository": "github:bpierre/dnum",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "bunup": "^0.16.10",
    "dprint": "^0.50.2",
    "oxlint": "^1.31.0",
    "oxlint-tsgolint": "^0.8.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "from-exponential": "^1.1.1"
  },
  "scripts": {
    "build": "bunup --format esm,cjs",
    "test": "bun test",
    "format": "dprint fmt",
    "lint": "oxlint --type-aware ./src",
    "coverage": "bun test --coverage"
  }
}