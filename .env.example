# Copy this file to `.env` and fill in real values.
# Never commit real secrets.

# ---------------------------------------------------------------------------
# Core LLM credentials (required for `python -m server.live_runner`)
# ---------------------------------------------------------------------------
AZURE_API_KEY=
AZURE_OPENAI_API_ENDPOINT=https://your-azure-openai-resource.openai.azure.com/
DDFT_MODELS_ENDPOINT=https://your-azure-ai-foundry-endpoint.openai.azure.com/v1

# Optional provider endpoint passed through to framework APIs.
AZURE_ANTHROPIC_API_ENDPOINT=

# ---------------------------------------------------------------------------
# Framework service endpoints (optional; defaults are localhost)
# ---------------------------------------------------------------------------
CDCT_API_URL=https://cdct-framework.vercel.app/
DDFT_API_URL=https://ddft-framework.vercel.app/
EECT_API_URL=https://eect-framework.vercel.app/

# ---------------------------------------------------------------------------
# Filecoin / Synapse storage (optional, enables real CID uploads)
# ---------------------------------------------------------------------------
FILECOIN_PRIVATE_KEY=
FILECOIN_NETWORK=calibration
FILECOIN_RPC=https://api.calibration.node.glif.io/rpc/v1

# ---------------------------------------------------------------------------
# Smart contract deployment (optional, for `contracts/`)
# ---------------------------------------------------------------------------
PRIVATE_KEY=
CALIBNET_RPC_URL=https://api.calibration.node.glif.io/rpc/v1

# Optional addresses emitted by `contracts/scripts/deploy.js`.
CGAE_REGISTRY_ADDRESS=
CGAE_ESCROW_ADDRESS=

# ---------------------------------------------------------------------------
# Dashboard (optional, for Streamlit Cloud -> Modal backend)
# ---------------------------------------------------------------------------
MODAL_ENDPOINT=
